<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_rover">
  
  <!-- Include all sensor files -->
  <xacro:include filename="$(find my_rover_package)/urdf/lidar.xacro"/>
  <xacro:include filename="$(find my_rover_package)/urdf/camera.xacro"/>
  <xacro:include filename="$(find my_rover_package)/urdf/imu.xacro"/>
  <xacro:include filename="$(find my_rover_package)/urdf/gps.xacro"/>
  <xacro:include filename="$(find my_rover_package)/urdf/ultrasonic.xacro"/>
  
  <!-- MAIN CHASSIS - DARK BLUE -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.7 0.45 0.18"/>
      </geometry>
      <material name="chassis_blue">
        <color rgba="0.1 0.2 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.7 0.45 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <inertia ixx="0.15" ixy="0.0" ixz="0.0" iyy="0.15" iyz="0.0" izz="0.15"/>
    </inertial>
  </link>
  
  <!-- Gazebo color for chassis -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  
  <!-- RPLIDAR A2M8 - BRIGHT RED -->
  <xacro:lidar_sensor parent="base_link">
    <origin xyz="0.0 0 0.18" rpy="0 0 0"/>
  </xacro:lidar_sensor>
  
  <!-- Camera - BLACK -->
  <xacro:camera_sensor parent="base_link" camera_name="front_camera">
    <origin xyz="0.37 0 0.06" rpy="0 0 0"/>
  </xacro:camera_sensor>
  
  <!-- IMU - BRIGHT GREEN -->
  <xacro:imu_sensor parent="base_link">
    <origin xyz="0.0 0 0.12" rpy="0 0 0"/>
  </xacro:imu_sensor>
  
  <!-- GPS - ORANGE -->
  <xacro:gps_sensor parent="base_link">
    <origin xyz="-0.25 0 0.22" rpy="0 0 0"/>
  </xacro:gps_sensor>
  
  <!-- 4x Ultrasonic - YELLOW -->
  <xacro:ultrasonic_sensor name="ultrasonic_front" parent="base_link">
    <origin xyz="0.37 0 0.0" rpy="0 0 0"/>
  </xacro:ultrasonic_sensor>
  
  <xacro:ultrasonic_sensor name="ultrasonic_back" parent="base_link">
    <origin xyz="-0.37 0 0.0" rpy="0 0 3.14159"/>
  </xacro:ultrasonic_sensor>
  
  <xacro:ultrasonic_sensor name="ultrasonic_left" parent="base_link">
    <origin xyz="0 0.24 0.0" rpy="0 0 1.5708"/>
  </xacro:ultrasonic_sensor>
  
  <xacro:ultrasonic_sensor name="ultrasonic_right" parent="base_link">
    <origin xyz="0 -0.24 0.0" rpy="0 0 -1.5708"/>
  </xacro:ultrasonic_sensor>
  
  <!-- Battery Pack Indicators - CYAN -->
  <link name="battery_left">
    <visual>
      <geometry>
        <box size="0.15 0.08 0.05"/>
      </geometry>
      <material name="battery_cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="battery_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_left"/>
    <origin xyz="-0.15 0.15 -0.08" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="battery_left">
    <material>Gazebo/Turquoise</material>
  </gazebo>
  
  <link name="battery_right">
    <visual>
      <geometry>
        <box size="0.15 0.08 0.05"/>
      </geometry>
      <material name="battery_cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="battery_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_right"/>
    <origin xyz="-0.15 -0.15 -0.08" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="battery_right">
    <material>Gazebo/Turquoise</material>
  </gazebo>
  
  <!-- Motor Controllers - MAGENTA -->
  <link name="motor_controller_left">
    <visual>
      <geometry>
        <box size="0.08 0.06 0.03"/>
      </geometry>
      <material name="controller_magenta">
        <color rgba="1 0 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="motor_controller_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_controller_left"/>
    <origin xyz="0.1 0.18 -0.05" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="motor_controller_left">
    <material>Gazebo/Purple</material>
  </gazebo>
  
  <link name="motor_controller_right">
    <visual>
      <geometry>
        <box size="0.08 0.06 0.03"/>
      </geometry>
      <material name="controller_magenta">
        <color rgba="1 0 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="motor_controller_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_controller_right"/>
    <origin xyz="0.1 -0.18 -0.05" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="motor_controller_right">
    <material>Gazebo/Purple</material>
  </gazebo>
  
  <!-- Solar Panel - SKY BLUE -->
  <link name="solar_panel">
    <visual>
      <geometry>
        <box size="0.25 0.20 0.01"/>
      </geometry>
      <material name="solar_blue">
        <color rgba="0.3 0.7 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  
  <joint name="solar_panel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="solar_panel"/>
    <origin xyz="0.15 0 0.095" rpy="0 0.2 0"/>
  </joint>
  
  <gazebo reference="solar_panel">
    <material>Gazebo/SkyBlue</material>
  </gazebo>
  
  <!-- WiFi Antenna - WHITE -->
  <link name="wifi_antenna">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.08"/>
      </geometry>
      <material name="antenna_white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="wifi_antenna_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wifi_antenna"/>
    <origin xyz="-0.3 0 0.13" rpy="0 0.3 0"/>
  </joint>
  
  <gazebo reference="wifi_antenna">
    <material>Gazebo/White</material>
  </gazebo>
  
  <!-- 6 WHEELS - BLACK -->
  
  <!-- Left Front Wheel -->
  <link name="left_front_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_front_wheel"/>
    <origin xyz="0.2 0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="left_front_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Right Front Wheel -->
  <link name="right_front_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_front_wheel"/>
    <origin xyz="0.2 -0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="right_front_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Left Middle Wheel (Drive) -->
  <link name="left_middle_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="left_middle_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_middle_wheel"/>
    <origin xyz="0.0 0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="left_middle_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Right Middle Wheel (Drive) -->
  <link name="right_middle_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="right_middle_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_middle_wheel"/>
    <origin xyz="0.0 -0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="right_middle_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Left Rear Wheel -->
  <link name="left_rear_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_rear_wheel"/>
    <origin xyz="-0.2 0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="left_rear_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Right Rear Wheel -->
  <link name="right_rear_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.012" ixy="0.0" ixz="0.0" iyy="0.012" iyz="0.0" izz="0.012"/>
    </inertial>
  </link>
  
  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_rear_wheel"/>
    <origin xyz="-0.2 -0.25 -0.08" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="right_rear_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <!-- Differential drive plugin -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>
      <left_joint>left_middle_wheel_joint</left_joint>
      <right_joint>right_middle_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_diameter>0.18</wheel_diameter>
      <max_wheel_torque>30</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>
  </gazebo>
  
</robot>
